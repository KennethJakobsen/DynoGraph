<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RollerGraph.App.ViewModels"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="RollerGraph.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="500"
        Title="RollerGraph">

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="Connection">
        <NativeMenu>
          <NativeMenuItem Header="Replay CSV..." Command="{Binding ReplayCsvCommand}"/>
          <NativeMenuItemSeparator/>
          <NativeMenuItem Header="Settings..." Command="{Binding OpenSettingsCommand}"/>
        </NativeMenu>
      </NativeMenuItem>
      <NativeMenuItem Header="Run">
        <NativeMenu>
          <NativeMenuItem Header="Save Current Run" Command="{Binding SaveCurrentRunCommand}"/>
          <NativeMenuItem Header="Load Run..." Command="{Binding LoadSavedRunCommand}"/>
          <NativeMenuItem Header="Clear Saved Runs" Command="{Binding ClearSavedRunsCommand}"/>
        </NativeMenu>
      </NativeMenuItem>
      <NativeMenuItem Header="Output">
        <NativeMenu>
          <NativeMenuItem Header="Print" Command="{Binding PrintCommand}"/>
          <NativeMenuItem Header="Export PNG..." Command="{Binding ExportPngCommand}"/>
        </NativeMenu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <Window.KeyBindings>
    <KeyBinding Gesture="Escape" Command="{Binding ResetCommand}"/>
    <KeyBinding Gesture="Cmd+R" Command="{Binding ResetCommand}"/>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ResetCommand}"/>
    <KeyBinding Gesture="Cmd+K" Command="{Binding ToggleConnectionCommand}"/>
    <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleConnectionCommand}"/>
    <KeyBinding Gesture="Cmd+O"  Command="{Binding ReplayCsvCommand}"/>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding ReplayCsvCommand}"/>
    <KeyBinding Gesture="Cmd+E"  Command="{Binding ExportPngCommand}"/>
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportPngCommand}"/>
    <KeyBinding Gesture="Cmd+P"  Command="{Binding PrintCommand}"/>
    <KeyBinding Gesture="Ctrl+P" Command="{Binding PrintCommand}"/>
    <KeyBinding Gesture="Cmd+B"  Command="{Binding SaveCurrentRunCommand}"/>
    <KeyBinding Gesture="Ctrl+B" Command="{Binding SaveCurrentRunCommand}"/>
    <KeyBinding Gesture="Cmd+Shift+B"  Command="{Binding ClearSavedRunsCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+B" Command="{Binding ClearSavedRunsCommand}"/>
    <KeyBinding Gesture="Cmd+OemComma"  Command="{Binding OpenSettingsCommand}"/>
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}"/>
  </Window.KeyBindings>

  <DockPanel LastChildFill="True">

    <!-- Menu bar -->
    <Menu Name="FallbackMenuBar" DockPanel.Dock="Top">
      <MenuItem Header="_Connection">
        <MenuItem Header="_Replay CSV..." Command="{Binding ReplayCsvCommand}"/>
        <Separator/>
        <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}"/>
      </MenuItem>
      <MenuItem Header="_Run">
        <MenuItem Header="_Save Current Run" Command="{Binding SaveCurrentRunCommand}"/>
        <MenuItem Header="_Load Run..." Command="{Binding LoadSavedRunCommand}"/>
        <MenuItem Header="_Clear Saved Runs" Command="{Binding ClearSavedRunsCommand}"/>
      </MenuItem>
      <MenuItem Header="_Output">
        <MenuItem Header="_Print" Command="{Binding PrintCommand}"/>
        <MenuItem Header="_Export PNG..." Command="{Binding ExportPngCommand}"/>
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Padding="10,8" BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Text="Port:" VerticalAlignment="Center"/>
        <ComboBox MinWidth="200"
                  ItemsSource="{Binding AvailablePorts}"
                  SelectedItem="{Binding SelectedPort}"/>
        <Button Width="32" Height="32" Padding="6"
                Command="{Binding RefreshPortsCommand}"
                ToolTip.Tip="Refresh ports">
          <PathIcon Width="16" Height="16"
                    Data="M17.65,6.35A8,8 0,1 0,19.73 14H17.73A6,6 0,1 1,16.24 7.76L13,11H20V4Z"/>
        </Button>
        <Button Width="32" Height="32" Padding="6"
                Command="{Binding ConnectCommand}"
                ToolTip.Tip="Connect">
          <PathIcon Width="16" Height="16"
                    Data="M7,2H9V7H11V2H13V7H15V2H17V8C17,10.76 14.76,13 12,13C9.24,13 7,10.76 7,8V2M11,13H13V22H11V13Z"/>
        </Button>
        <Button Width="32" Height="32" Padding="6"
                Command="{Binding DisconnectCommand}"
                ToolTip.Tip="Disconnect">
          <PathIcon Width="16" Height="16"
                    Data="M3,4.27L4.28,3L21,19.72L19.73,21L15.76,17.03C14.96,17.63 14,18 13,18V22H11V18C8.24,18 6,15.76 6,13V10H8V13C8,14.66 9.34,16 11,16H13C13.43,16 13.84,15.91 14.21,15.75L11.46,13H10V11.54L8,9.54V10H6V7.54L3,4.27M16,10V13C16,13.34 15.94,13.67 15.83,13.97L14.14,12.28C14.05,11.86 13.83,11.5 13.54,11.22L10,7.68V2H12V7H14V2H16V7H18V2H20V8C20,8.73 19.84,9.42 19.55,10.04L17.92,8.41C17.98,8.28 18,8.14 18,8V10H16Z"/>
        </Button>
        <Separator Width="12"/>
        <Button Width="32" Height="32" Padding="6"
                Command="{Binding ResetCommand}"
                ToolTip.Tip="Reset (Esc)">
          <PathIcon Width="16" Height="16"
                    Data="M12,5V2L7,7L12,12V9C15.31,9 18,11.69 18,15C18,16.01 17.75,16.96 17.3,17.8L18.76,19.26C19.54,18.03 20,16.57 20,15C20,10.58 16.42,7 12,7V5M6.7,12.2L5.24,10.74C4.46,11.97 4,13.43 4,15C4,19.42 7.58,23 12,23V26L17,21L12,16V19C8.69,19 6,16.31 6,13C6,12.99 6,12.99 6,12.98C6.13,12.71 6.36,12.43 6.7,12.2Z"/>
        </Button>
        <Separator Width="12"/>
        <CheckBox Content="Smoothing" IsChecked="{Binding SmoothingEnabled}"/>
      </StackPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Padding="10,6" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
          <TextBlock>
            <Run Text="Samples: "/>
            <Run Text="{Binding Chart.SampleCount}" FontWeight="SemiBold"/>
          </TextBlock>
          <TextBlock>
            <Run Text="Bad lines: "/>
            <Run Text="{Binding BadLineCount}" FontWeight="SemiBold"/>
          </TextBlock>
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding LogFilePath}" Opacity="0.6"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Opacity="0.85"/>
      </Grid>
    </Border>

    <!-- Main content: chart + side panel -->
    <Grid ColumnDefinitions="*,260" Margin="6">

      <lvc:CartesianChart Grid.Column="0"
                          Name="ChartHost"
                          Series="{Binding Chart.Series}"
                          XAxes="{Binding Chart.XAxes}"
                          YAxes="{Binding Chart.YAxes}"/>

      <!-- Side panel: peak stats + saved runs -->
      <Grid Grid.Column="1" Margin="8,0,0,0" RowDefinitions="Auto,*" RowSpacing="8">

        <!-- Peak stats card -->
        <Border Grid.Row="0" Padding="14" CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
          <StackPanel Spacing="12">
            <TextBlock Text="PEAK STATS" FontSize="11" FontWeight="Bold" Opacity="0.6"/>

            <StackPanel Spacing="2">
              <TextBlock Text="Peak HP" FontSize="11" Opacity="0.7"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding Chart.PeakHp, StringFormat='{}{0:F1}'}"
                           FontSize="26" FontWeight="Bold" Foreground="#FF8A00"/>
                <TextBlock Text="HP" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4" Opacity="0.7"/>
              </StackPanel>
              <TextBlock FontSize="11" Opacity="0.6">
                <Run Text="@ "/>
                <Run Text="{Binding Chart.PeakHpSpeed, StringFormat='{}{0:F0}'}"/>
                <Run Text=" km/h"/>
              </TextBlock>
            </StackPanel>

            <Separator Opacity="0.3"/>

            <StackPanel Spacing="2">
              <TextBlock Text="Peak NM" FontSize="11" Opacity="0.7"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding Chart.PeakNm, StringFormat='{}{0:0.##}'}"
                           FontSize="26" FontWeight="Bold" Foreground="#00B8A9"/>
                <TextBlock Text="NM" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4" Opacity="0.7"/>
              </StackPanel>
              <TextBlock FontSize="11" Opacity="0.6">
                <Run Text="@ "/>
                <Run Text="{Binding Chart.PeakNmSpeed, StringFormat='{}{0:0.##}'}"/>
                <Run Text=" km/h"/>
              </TextBlock>
            </StackPanel>

            <Separator Opacity="0.3"/>

            <StackPanel Spacing="2">
              <TextBlock Text="Peak Speed" FontSize="11" Opacity="0.7"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding Chart.PeakSpeed, StringFormat='{}{0:0.##}'}"
                           FontSize="26" FontWeight="Bold"/>
                <TextBlock Text="km/h" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4" Opacity="0.7"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Saved Runs card -->
        <Border Grid.Row="1" Padding="14" CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
              <TextBlock Grid.Column="0" Text="SAVED RUNS" FontSize="11" FontWeight="Bold" Opacity="0.6" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="+ Save current" FontSize="11"
                      Command="{Binding SaveCurrentRunCommand}"/>
            </Grid>

            <TextBlock Text="No saved runs yet. Use Save Run (Cmd/Ctrl+B) to capture the current chart."
                       FontSize="11" Opacity="0.5" TextWrapping="Wrap"
                       IsVisible="{Binding SavedRuns.Items.Count, Converter={x:Static vm:IntToBoolConverter.Instance}, ConverterParameter=invert}"/>

            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding SavedRuns.Items}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SavedRunViewModel">
                    <Border Margin="0,2" Padding="6" CornerRadius="4"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6">
                        <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                Background="{Binding Color, Converter={x:Static vm:HexToBrushConverter.Instance}}"
                                VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                          <TextBlock FontSize="10" Opacity="0.6">
                            <Run Text="{Binding SampleCount}"/>
                            <Run Text=" samples"/>
                          </TextBlock>
                        </StackPanel>
                        <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible}"
                                  Click="OnSavedRunVisibilityToggled"
                                  ToolTip.Tip="Show/hide on chart"/>
                        <Button Grid.Column="3" Content="..." FontSize="11" Padding="6,2"
                                Click="OnSavedRunRenameClicked"/>
                        <Button Grid.Column="4" Content="x" FontSize="11" Padding="6,2"
                                Click="OnSavedRunDeleteClicked"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>

      </Grid>
    </Grid>
  </DockPanel>
</Window>
