<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RollerGraph.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="560"
        x:Class="RollerGraph.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="Settings">

  <Grid RowDefinitions="*,Auto" Margin="16">

    <TabControl Grid.Row="0">

      <!-- General tab -->
      <TabItem Header="General">
        <StackPanel Spacing="12" Margin="6,10,6,0">

          <TextBlock Text="Serial" FontWeight="Bold" Opacity="0.7"/>
          <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Baud rate" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           Value="{Binding BaudRate}"
                           Minimum="1200" Maximum="921600" Increment="1200"
                           FormatString="0"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum speed (km/h)" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding MinSpeedKmh}"
                           Minimum="0" Maximum="200" Increment="1"
                           FormatString="0.0"/>
          </Grid>

          <TextBlock Text="Smoothing" FontWeight="Bold" Opacity="0.7" Margin="0,8,0,0"/>
          <Grid ColumnDefinitions="200,*" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="Rolling window (samples)" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="1"
                           Value="{Binding SmoothingWindow}"
                           Minimum="1" Maximum="200" Increment="1"
                           FormatString="0"/>
          </Grid>
          <TextBlock Text="Active only when the Smoothing checkbox is on. 1 disables smoothing."
                     Opacity="0.6" FontSize="11"/>

          <TextBlock Text="Axis defaults" FontWeight="Bold" Opacity="0.7" Margin="0,8,0,0"/>
          <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Default HP max" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           Value="{Binding DefaultHpMax}"
                           Minimum="1" Maximum="1000" Increment="5"
                           FormatString="0"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Default NM max" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding DefaultNmMax}"
                           Minimum="1" Maximum="2000" Increment="5"
                           FormatString="0"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Default speed max (km/h)" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1"
                           Value="{Binding DefaultSpeedMax}"
                           Minimum="10" Maximum="500" Increment="10"
                           FormatString="0"/>
          </Grid>

        </StackPanel>
      </TabItem>

      <!-- Channel adjustments tab -->
      <TabItem Header="Adjustments">
        <ScrollViewer>
          <StackPanel Spacing="14" Margin="6,10,6,0">

            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12">
              Each channel can be corrected. Use Factor + Offset for a simple
              linear correction (value' = value * Factor + Offset), or supply
              a math expression to override using x as the input.
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
              Operators: + - * / ^ (power). Functions: abs, sqrt, log, log10,
              exp, sin, cos, tan, min(a,b), max(a,b), pow(a,b). Constants: pi, e.
              Examples: x * 1.05    x / 0.92 + 1.5    pow(x, 0.95)
            </TextBlock>

            <ContentControl Content="{Binding SpeedAdjustment}"
                            ContentTemplate="{StaticResource AdjustmentTemplate}"/>
            <ContentControl Content="{Binding NmAdjustment}"
                            ContentTemplate="{StaticResource AdjustmentTemplate}"/>
            <ContentControl Content="{Binding HpAdjustment}"
                            ContentTemplate="{StaticResource AdjustmentTemplate}"/>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancelClicked"/>
      <Button Content="Save" Click="OnSaveClicked" Classes="accent"/>
    </StackPanel>
  </Grid>

  <Window.Resources>
    <DataTemplate x:Key="AdjustmentTemplate" x:DataType="vm:ChannelAdjustmentViewModel">
      <Border Padding="10" CornerRadius="6"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding ChannelName}" FontWeight="Bold"/>
            <TextBlock Text="(" Opacity="0.5"/>
            <TextBlock Text="{Binding Unit}" Opacity="0.5"/>
            <TextBlock Text=")" Opacity="0.5"/>
          </StackPanel>

          <Grid ColumnDefinitions="80,*,80,*" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="Factor" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="1"
                           Value="{Binding Factor}"
                           Minimum="-1000" Maximum="1000" Increment="0.01"
                           FormatString="0.####"/>

            <TextBlock Grid.Column="2" Text="Offset" VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="3"
                           Value="{Binding Offset}"
                           Minimum="-10000" Maximum="10000" Increment="0.5"
                           FormatString="0.####"/>
          </Grid>

          <TextBlock Text="Expression (overrides factor/offset when set):" FontSize="11" Opacity="0.7"/>
          <TextBox Text="{Binding Expression}" PlaceholderText="e.g. x * 1.05  or  x / 0.92 + 1.5"
                   FontFamily="Menlo, Consolas, monospace"/>
          <TextBlock Text="{Binding ExpressionError}" Foreground="#E04040" FontSize="11"
                     IsVisible="{Binding ExpressionError, Converter={x:Static vm:NotNullToBoolConverter.Instance}}"/>
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

</Window>
