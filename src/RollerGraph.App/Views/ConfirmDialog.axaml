<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RollerGraph.App.Views.ConfirmDialog"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="Confirm">
  <Grid RowDefinitions="*,Auto" Margin="16">
    <TextBlock Grid.Row="0" Name="MessageText" TextWrapping="Wrap"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Name="CancelButton" Content="Cancel" Click="OnCancelClicked"/>
      <Button Name="ConfirmButton" Content="OK" Click="OnConfirmClicked" Classes="accent" IsDefault="True"/>
    </StackPanel>
  </Grid>
</Window>
